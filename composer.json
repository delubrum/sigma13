{
    "name": "sigma/sigma13",
    "type": "project",
    "description": "SIGMA ERP/CMMS - Laravel 13 ADR Architecture",
    "keywords": [
        "laravel",
        "framework",
        "frankenphp",
        "sigma"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.5",
        "aws/aws-sdk-php": "^3.376",
        "google/recaptcha": "^1.4",
        "guzzlehttp/guzzle": "^7.9",
        "laravel/ai": "*",
        "laravel/framework": "^13.0",
        "laravel/octane": "^2.17",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.32",
        "lorisleiva/laravel-actions": "^2.10",
        "predis/predis": "^3.4",
        "spatie/laravel-activitylog": "^5.0",
        "spatie/laravel-csp": "^3.23",
        "spatie/laravel-data": "^4.21",
        "spatie/laravel-honeypot": "^4.7",
        "spatie/laravel-medialibrary": "^11.21",
        "spatie/laravel-query-builder": "^7.1",
        "spatie/simple-excel": "^3.9"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.2",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.9",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-dev": [
            "fuser -k 8000/tcp || true",
            "fuser -k 5174/tcp || true",
            "sudo systemctl restart valkey || sudo systemctl restart redis-server || true",
            "sleep 1",
            "(nc -z 127.0.0.1 6379) || (echo 'Valkey no responde en 127.0.0.1:6379' && exit 1)",
            "@php artisan queue:clear --ansi",
            "@php artisan view:clear --ansi",
            "@php artisan config:clear --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "@pre-dev",
            "npx concurrently -c \"#9333ea,#c026d3,#2ecc71\" \"php artisan octane:start --watch\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names=server,queue,vite"
        ],
        "lint": "pint",
        "rector": "rector process",
        "stan": "phpstan analyse",
        "test:arch": "pest tests/Architecture/StructuralTest.php",
        "check-all": [
            "@rector",
            "@lint",
            "@stan"
        ],
        "check-arch": [
            "@test:arch"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
