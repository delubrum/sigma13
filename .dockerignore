# .dockerignore - SIGMA Architecture (2026 Ready)

# --- Dependencias ---
# Nunca copiar vendor ni node_modules; se instalan en el Stage 2 del Dockerfile
vendor/
node_modules/

# --- Caché de Laravel ---
# El Dockerfile genera versiones limpias en el Stage 3 (Optimización)
bootstrap/cache/*.php
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*.php

# --- Entorno y Seguridad ---
# Evita fugas de credenciales y logs de desarrollo
.env
.env.backup
.env.production
storage/logs/*.log

# --- Control de Versiones y Git ---
.git/
.gitignore
.gitattributes
.github/

# --- Herramientas de Desarrollo y Calidad ---
# Estas herramientas corren en el Host o vía Sail, no dentro de la imagen de Prod/Runtime
.dockerignore
docker-compose.yml
compose.yaml
docker/
.phpunit.result.cache
.pest_tracker
rector.php
phpstan.neon
phpunit.xml
auth.json

# --- Basura del Sistema Operativo ---
# Crítico para evitar errores de permisos en sistemas Debian/LMDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp